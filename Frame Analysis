<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=1400"/>
<title>Frame Analyzer — 2D Plane Frame</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#0b0d12;--surface:#13161e;--surface2:#191d28;--border:#222736;--accent:#00e5ff;--accent2:#ff6b35;--accent3:#a8ff78;--accent4:#c084fc;--text:#e8ecf4;--muted:#8896b8;--r:#ffd60a;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'Space Mono',monospace;min-height:100vh;width:1400px;overflow-x:visible;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.025) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0;}
header{position:relative;z-index:1;padding:14px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
header h1{font-family:'Space Mono',monospace;font-size:19px;color:var(--accent);}
.mbadge{font-family:'Space Mono',monospace;font-size:12px;padding:2px 8px;border-radius:9px;background:rgba(192,132,252,.12);color:var(--accent4);border:1px solid rgba(192,132,252,.28);}
.hright{margin-left:auto;display:flex;gap:7px;}
/* 3-column layout */
.main{position:relative;z-index:1;display:grid;grid-template-columns:300px 600px 260px;width:1160px;align-items:stretch;}
.col-nodes{background:var(--surface);border-right:1px solid var(--border);padding:14px 12px;overflow-y:auto;min-width:270px;}
.col-members{background:var(--surface);border-right:1px solid var(--border);padding:14px 12px;overflow-y:auto;min-width:270px;}
.col-canvas{display:flex;flex-direction:column;min-width:500px;}
/* Section title */
.sec{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:.15em;color:#c8d0e8;text-transform:uppercase;margin:14px 0 8px;padding-bottom:4px;border-bottom:1px solid var(--border);}
.sec:first-child{margin-top:0;}
.field{margin-bottom:8px;}
label{display:block;font-size:12px;color:#c8d0e8;margin-bottom:3px;font-family:'Space Mono',monospace;}
input[type=number],select{width:100%;background:var(--surface2);border:1px solid var(--border);color:var(--text);padding:7px 9px;border-radius:5px;font-family:'Space Mono',monospace;font-size:13px;outline:none;transition:border-color .2s;}
input[type=number]:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(0,229,255,.08);}
/* Cards */
.scard,.card{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:9px 10px;margin-bottom:7px;position:relative;}
.scard-hd{display:flex;align-items:center;gap:7px;margin-bottom:7px;padding-right:20px;}
.snum{font-family:'Space Mono',monospace;font-size:12px;font-weight:700;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(0,229,255,.18);color:var(--accent);border:1px solid rgba(0,229,255,.4);}
.snum.m{background:rgba(192,132,252,.18);color:var(--accent4);border-color:rgba(192,132,252,.4);}
.snum.s{background:rgba(255,214,10,.18);color:#ffd60a;border-color:rgba(255,214,10,.4);}
.snum.l{background:rgba(255,107,53,.18);color:var(--accent2);border-color:rgba(255,107,53,.4);}
.slbl{font-family:'Space Mono',monospace;font-size:12px;color:var(--muted);flex:1;}
.srem,.crem{background:none;border:none;color:#8896b8;cursor:pointer;font-size:13px;padding:2px 5px;border-radius:3px;transition:color .2s;position:absolute;top:6px;right:6px;line-height:1;}
.srem:hover,.crem:hover{color:#ff4d6d;}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:5px;}
/* Buttons */
.add-btn{width:100%;padding:7px;background:rgba(0,229,255,.05);border:1px dashed rgba(0,229,255,.2);color:var(--accent);border-radius:5px;cursor:pointer;font-family:'Space Mono',monospace;font-size:12px;transition:.2s;margin-bottom:4px;}
.add-btn:hover{background:rgba(0,229,255,.1);border-color:var(--accent);}
.add-btn.m{border-color:rgba(192,132,252,.25);color:var(--accent4);background:rgba(192,132,252,.05);}
.add-btn.m:hover{background:rgba(192,132,252,.1);border-color:var(--accent4);}
.add-btn.s{border-color:rgba(255,214,10,.25);color:#ffd60a;background:rgba(255,214,10,.05);}
.add-btn.s:hover{background:rgba(255,214,10,.1);border-color:#ffd60a;}
.add-btn.l{border-color:rgba(255,107,53,.25);color:var(--accent2);background:rgba(255,107,53,.05);}
.add-btn.l:hover{background:rgba(255,107,53,.1);border-color:var(--accent2);}
.calc-btn{width:100%;padding:11px;background:var(--accent);color:#000;border:none;border-radius:6px;font-family:'Space Mono',monospace;font-size:14px;font-weight:700;cursor:pointer;margin-bottom:12px;letter-spacing:.8px;transition:.2s;}
.calc-btn:hover{background:#2ef0ff;transform:translateY(-1px);box-shadow:0 4px 18px rgba(0,229,255,.25);}
.tbtn2{padding:5px 10px;background:var(--surface2);border:1px solid var(--border);color:var(--muted);border-radius:4px;cursor:pointer;font-family:'Space Mono',monospace;font-size:11px;transition:.15s;}
.tbtn2:hover{border-color:var(--accent);color:var(--accent);}
.tbtn2.on{background:rgba(0,229,255,.08);border-color:var(--accent);color:var(--accent);}
/* Error */
.err{background:rgba(255,77,109,.09);border:1px solid rgba(255,77,109,.28);color:#ff4d6d;padding:9px 12px;border-radius:6px;font-size:13px;margin-bottom:10px;}
/* Canvas toolbar */
.canvas-toolbar{display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;}
.tinfo{font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);}
#frame-canvas{display:block;cursor:grab;width:100%;height:580px;}
/* Results panel */
.results-panel{background:var(--surface);border-left:1px solid var(--border);padding:14px 12px;overflow-y:auto;}
.rcard{background:var(--surface2);border:1px solid var(--border);border-radius:7px;padding:9px 12px;margin-bottom:8px;border-left:3px solid var(--accent);}
.rcard.m{border-left-color:var(--accent4);}
.rcard.s{border-left-color:#ffd60a;}
.rl{font-family:'Space Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.05em;margin-bottom:4px;}
.rv{font-family:'Space Mono',monospace;font-size:15px;color:var(--accent);font-weight:700;}
.sum-table{width:100%;border-collapse:collapse;font-family:'Space Mono',monospace;font-size:12px;}
.sum-table th{text-align:left;padding:4px 6px;border-bottom:1px solid var(--border);color:var(--muted);font-size:10px;letter-spacing:.1em;text-transform:uppercase;}
.sum-table td{padding:4px 6px;border-bottom:1px solid rgba(255,255,255,.03);}
.sum-table td.v{color:var(--accent);text-align:right;}
.sum-table td.vn{color:var(--accent2);text-align:right;}
.dblock{background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:12px 14px;margin-bottom:10px;}
.input-panel{background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;min-width:300px;}
.tab-bar{display:grid;grid-template-columns:repeat(5,1fr);border-bottom:1px solid var(--border);flex-shrink:0;}
.tab{padding:9px 4px;text-align:center;font-family:'Space Mono',monospace;font-size:9px;letter-spacing:.08em;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:.15s;text-transform:uppercase;}
.tab.on{color:var(--accent);border-color:var(--accent);background:rgba(0,229,255,.04);}
.tab:hover:not(.on){color:var(--text);border-color:rgba(255,255,255,.15);}
.tab-body{flex:1;overflow-y:auto;padding:12px;}
.tab-pane{display:none;}.tab-pane.on{display:block;}
.dtitle{font-family:'Space Mono',monospace;font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;}
</style>
</head>
<body>
<header>
  <div style="width:32px;height:32px;background:rgba(0,229,255,.12);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:18px;border:1px solid rgba(0,229,255,.2);">🏗</div>
  <h1>FRAME ANALYZER</h1>
  <span style="color:#c8d0e8;font-size:14px;">2D Plane Frame</span>
  <span class="mbadge">DIRECT STIFFNESS METHOD</span>
  <div class="hright">
    <button class="tbtn2" onclick="resetView()">⌖ Reset View</button>
    <button class="tbtn2 on" id="btn-grid" onclick="toggleGrid()">Grid</button>
    <button class="tbtn2 on" id="btn-deformed" onclick="toggleDeformed()">Deformed</button>
    <button class="tbtn2 on" id="btn-labels" onclick="toggleLabels()">Labels</button>
  </div>
</header>

<div style="width:1400px;"><div class="main">
<!-- Col 1: Tabbed input panel -->
<div class="input-panel">
  <button class="calc-btn" style="margin:10px 10px 0;width:calc(100% - 20px);" onclick="analyze()">&#9654; Calculate</button>
  <div id="err-box" style="display:none;margin:6px 10px 0;"></div>
  <div class="tab-bar">
    <div class="tab on" id="tab-nodes" onclick="switchInputTab('nodes')">Nodes</div>
    <div class="tab" id="tab-supports" onclick="switchInputTab('supports')">Supports</div>
    <div class="tab" id="tab-members" onclick="switchInputTab('members')">Members</div>
    <div class="tab" id="tab-udl" onclick="switchInputTab('udl')">UDL</div>
    <div class="tab" id="tab-loads" onclick="switchInputTab('loads')">Loads</div>
  </div>
  <div class="tab-body">
    <div class="tab-pane on" id="pane-nodes">
      <div class="sec" style="margin-top:0">Nodes</div>
      <div id="node-list"></div>
      <button class="add-btn" onclick="addNode()">＋ Add Node</button>
    </div>
    <div class="tab-pane" id="pane-supports">
      <div class="sec" style="margin-top:0">Supports</div>
      <div id="supp-list"></div>
      <button class="add-btn s" onclick="addSupport()">＋ Add Support</button>
    </div>
    <div class="tab-pane" id="pane-members">
      <div class="sec" style="margin-top:0">Members</div>
      <div id="member-list"></div>
      <button class="add-btn m" onclick="addMember()">＋ Add Member</button>
    </div>
    <div class="tab-pane" id="pane-udl">
      <div class="sec" style="margin-top:0">Member Loads (UDL)</div>
      <div id="mload-list"></div>
      <button class="add-btn m" style="border-color:rgba(0,229,255,.25);color:var(--accent);" onclick="addMemberLoad()">＋ Add UDL on Member</button>
    </div>
    <div class="tab-pane" id="pane-loads">
      <div class="sec" style="margin-top:0">Nodal Loads</div>
      <div id="load-list"></div>
      <button class="add-btn l" onclick="addLoad()">＋ Add Nodal Load</button>
    </div>
  </div>
</div>

<!-- Col 3: Canvas + Results -->
<div style="display:flex;flex-direction:column;min-width:0;flex:1;">
<!-- ── Canvas toolbar ── -->
<div class="canvas-toolbar">
  <span class="tinfo" id="canvas-info">Scroll to zoom  •  Drag to pan</span>
  <button class="tbtn2 on" id="btn-deformed" onclick="toggleDeformed()">Deformed</button>
  <button class="tbtn2 on" id="btn-labels" onclick="toggleLabels()">Labels</button>
</div>
<!-- ── Canvas row ── -->
<div style="display:flex;min-width:0;">
  <canvas id="frame-canvas" style="flex:1;min-width:0;"></canvas>
</div>
<!-- 4 Diagram panels below canvas -->
<div id="diagram-panels" style="display:none;border-top:1px solid var(--border);overflow:hidden;">
  <div style="display:flex;align-items:center;gap:8px;padding:8px 14px;background:var(--surface2);border-bottom:1px solid var(--border);">
    <span style="font-family:'Space Mono',monospace;font-size:11px;color:var(--muted);">Diagram Scale:</span>
    <button class="tbtn2" onclick="changeDiagScale(-1)">−</button>
    <span id="diag-scale-lbl" style="font-family:'Space Mono',monospace;font-size:12px;color:var(--accent);min-width:50px;text-align:center;">0.200x</span>
    <button class="tbtn2" onclick="changeDiagScale(1)">+</button>
    <button class="tbtn2" onclick="diagScaleMult=0.2;document.getElementById('diag-scale-lbl').textContent='0.200x';if(results)drawAllDiagrams();">Reset</button>
  </div>
  <div style="display:flex;flex-direction:column;gap:1px;background:var(--border);">
    <div style="background:var(--surface);padding:12px 16px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;">Free Body Diagram</div>
      <canvas id="cv-fbd" style="display:block;width:560px;height:420px;"></canvas>
    </div>
    <div style="background:var(--surface);padding:12px 16px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;">Shear Force — V (kg)</div>
      <canvas id="cv-shear" style="display:block;width:560px;height:420px;"></canvas>
    </div>
    <div style="background:var(--surface);padding:12px 16px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;">Bending Moment — M (kg·m)</div>
      <canvas id="cv-moment" style="display:block;width:560px;height:420px;"></canvas>
    </div>
    <div style="background:var(--surface);padding:12px 16px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;">Deflection — v (mm)</div>
      <canvas id="cv-deflect" style="display:block;width:560px;height:420px;"></canvas>
    </div>
    <div style="background:var(--surface);padding:12px 16px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:#c8d0e8;margin-bottom:8px;">Local Axis (x̄, ȳ per Member)</div>
      <canvas id="cv-local" style="display:block;width:560px;height:420px;"></canvas>
    </div>
  </div>
</div><!-- end fixed-width inner -->
</div><!-- end col3 -->

<!-- Col 4: Results -->
<div class="results-panel" style="min-width:260px;max-width:260px;overflow-y:auto;">
  <div class="sec" style="margin-top:0">Results</div>
  <div id="results-content">
    <div style="font-size:12px;color:var(--muted);font-family:'Space Mono',monospace;text-align:center;padding:20px;">Run Calculate to see results</div>
  </div>
</div>
</div>
</div>

<script>
'use strict';
// ── State ────────────────────────────────────────────────────────────────────
var nodes={}, nodeCount=0;
var members={}, memberCount=0;
var supports={}, suppCount=0;
var loads={}, loadCount=0;
var results=null;
var memberLoads={}, mLoadCount=0;
var showDeformed=true, showLabels=true, showGrid=true;

// ── Canvas & viewport ────────────────────────────────────────────────────────
var cv=document.getElementById('frame-canvas');
var ctx=cv.getContext('2d');
var dpr=window.devicePixelRatio||1;
var vp={ox:0,oy:0,scale:80}; // origin in canvas px, scale=px/m
var dragging=false,dragStart={x:0,y:0},vpStart={ox:0,oy:0};

function resize(){
  var W=560;
  var H=520;
  cv.style.width=W+'px';
  cv.style.height=H+'px';
  cv.width=W*dpr; cv.height=H*dpr;
  draw();
}

function toCanvas(x,y){return{x:vp.ox+x*vp.scale,y:vp.oy-y*vp.scale};}
function toWorld(cx,cy){return{x:(cx-vp.ox)/vp.scale,y:(vp.oy-cy)/vp.scale};}

// ── Tab switching ────────────────────────────────────────────────────────────


// ── Node management ──────────────────────────────────────────────────────────
function addNode(xv,yv){
  nodeCount++;
  var id=nodeCount;
  xv=xv!=null?xv:0; yv=yv!=null?yv:0;
  nodes[id]={x:xv,y:yv};
  var d=document.createElement('div');
  d.className='card'; d.id='nc-'+id;
  d.innerHTML=
    '<button class="crem" onclick="removeNode('+id+')">✕</button>'+
    '<div class="card-hd"><span class="cnum">'+id+'</span><span class="clbl">Node #'+id+'</span></div>'+
    '<div class="row2">'+
    '<div class="field"><label>x (m)</label><input type="number" id="nx-'+id+'" value="'+xv+'" step="0.5" oninput="nodes['+id+'].x=+this.value;draw()"></div>'+
    '<div class="field"><label>y (m)</label><input type="number" id="ny-'+id+'" value="'+yv+'" step="0.5" oninput="nodes['+id+'].y=+this.value;draw()"></div>'+
    '</div>';
  document.getElementById('node-list').appendChild(d);
  draw(); return id;
}
function removeNode(id){
  delete nodes[id];
  var el=document.getElementById('nc-'+id); if(el)el.remove();
  draw();
}

// ── Member management ────────────────────────────────────────────────────────
function addMember(){
  memberCount++;
  var id=memberCount;
  var nids=Object.keys(nodes);
  var ni=nids[0]||1, nj=nids[1]||2;
  members[id]={ni:+ni,nj:+nj,E:2100000,A:10,I:100};
  var d=document.createElement('div');
  d.className='card'; d.id='mc-'+id;
  d.innerHTML=
    '<button class="crem" onclick="removeMember('+id+')">✕</button>'+
    '<div class="card-hd"><span class="cnum m">'+id+'</span><span class="clbl">Member #'+id+'</span></div>'+
    '<div class="row2"><div class="field"><label>Node i</label>'+
    '<input type="number" id="mni-'+id+'" value="'+ni+'" step="1" min="1" oninput="members['+id+'].ni=+this.value;draw()"></div>'+
    '<div class="field"><label>Node j</label>'+
    '<input type="number" id="mnj-'+id+'" value="'+nj+'" step="1" min="1" oninput="members['+id+'].nj=+this.value;draw()"></div></div>'+
    '<div class="row3">'+
    '<div class="field"><label>E (kg/cm²)</label><input type="number" id="me-'+id+'" value="2100000" step="100000" oninput="members['+id+'].E=+this.value"></div>'+
    '<div class="field"><label>A (cm²)</label><input type="number" id="ma-'+id+'" value="10" step="1" oninput="members['+id+'].A=+this.value"></div>'+
    '<div class="field"><label>I (cm⁴)</label><input type="number" id="mi-'+id+'" value="100" step="10" oninput="members['+id+'].I=+this.value"></div>'+
    '</div>';
  document.getElementById('member-list').appendChild(d);
  draw();
}
function removeMember(id){
  delete members[id];
  var el=document.getElementById('mc-'+id); if(el)el.remove();
  draw();
}

// ── Support management ───────────────────────────────────────────────────────
function addSupport(){
  suppCount++;
  var id=suppCount;
  var nids=Object.keys(nodes);
  var ni=nids[0]||1;
  supports[id]={node:+ni,type:'fixed'};
  var d=document.createElement('div');
  d.className='card'; d.id='sc-'+id;
  d.innerHTML=
    '<button class="crem" onclick="removeSupport('+id+')">✕</button>'+
    '<div class="card-hd"><span class="cnum s">'+id+'</span><span class="clbl">Support #'+id+'</span></div>'+
    '<div class="row2">'+
    '<div class="field"><label>Node</label>'+
    '<input type="number" id="sn-'+id+'" value="'+ni+'" step="1" min="1" oninput="supports['+id+'].node=+this.value;draw()"></div>'+
    '<div class="field"><label>Type</label>'+
    '<select id="st-'+id+'" onchange="supports['+id+'].type=this.value;draw()">'+
    '<option value="fixed">▐ Fixed</option>'+
    '<option value="pin">△ Pin</option>'+
    '<option value="roller_x">○ Roller (free X)</option>'+
    '<option value="roller_y">○ Roller (free Y)</option>'+
    '</select></div></div>';
  document.getElementById('supp-list').appendChild(d);
  draw();
}
function removeSupport(id){
  delete supports[id];
  var el=document.getElementById('sc-'+id); if(el)el.remove();
  draw();
}

// ── Load management ──────────────────────────────────────────────────────────
function addMemberLoad(){
  mLoadCount++;
  var id=mLoadCount;
  var mids=Object.keys(members);
  var mid=mids[0]||1;
  memberLoads[id]={member:+mid,w:10};
  var d=document.createElement('div');
  d.className='scard'; d.id='mlc-'+id;
  d.innerHTML=
    '<button class="crem" onclick="removeMemberLoad('+id+')">✕</button>'+
    '<div class="card-hd"><span class="cnum m">'+id+'</span><span class="clbl">UDL #'+id+'</span></div>'+
    '<div class="row2">'+
    '<div class="field"><label>Member #</label>'+
    '<input type="number" id="mlm-'+id+'" value="'+mid+'" step="1" min="1" oninput="memberLoads['+id+'].member=+this.value"></div>'+
    '<div class="field"><label>w (kg/m) ↓+</label>'+
    '<input type="number" id="mlw-'+id+'" value="10" step="1" oninput="memberLoads['+id+'].w=+this.value"></div>'+
    '</div>';
  document.getElementById('mload-list').appendChild(d);
}
function removeMemberLoad(id){
  delete memberLoads[id];
  var el=document.getElementById('mlc-'+id);if(el)el.remove();
}

function addLoad(){
  loadCount++;
  var id=loadCount;
  var nids=Object.keys(nodes);
  var ni=nids[0]||1;
  loads[id]={node:+ni,Fx:0,Fy:0,M:0};
  var d=document.createElement('div');
  d.className='card'; d.id='lc-'+id;
  d.innerHTML=
    '<button class="crem" onclick="removeLoad('+id+')">✕</button>'+
    '<div class="card-hd"><span class="cnum l">'+id+'</span><span class="clbl">Load #'+id+'</span></div>'+
    '<div class="field"><label>Node</label>'+
    '<input type="number" id="ln-'+id+'" value="'+ni+'" step="1" min="1" oninput="loads['+id+'].node=+this.value"></div>'+
    '<div class="row3">'+
    '<div class="field"><label>Fx (kg) →</label><input type="number" id="lfx-'+id+'" value="0" step="1" oninput="loads['+id+'].Fx=+this.value"></div>'+
    '<div class="field"><label>Fy (kg) ↑</label><input type="number" id="lfy-'+id+'" value="0" step="1" oninput="loads['+id+'].Fy=+this.value"></div>'+
    '<div class="field"><label>M (kg·m) ↺+</label><input type="number" id="lm-'+id+'" value="0" step="1" oninput="loads['+id+'].M=+this.value"></div>'+
    '</div>';
  document.getElementById('load-list').appendChild(d);
}
function removeLoad(id){
